{
  "name": "acode-aqui-marketplace-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "db:schema": "node scripts/db.mjs schema",
    "db:seed": "node scripts/db.mjs seed",
    "db:reset": "node scripts/db.mjs reset",
    "prisma:generate": "node scripts/prisma.mjs generate",
    "prisma:migrate": "node scripts/prisma.mjs migrate dev",
    "prisma:deploy": "node scripts/prisma.mjs migrate deploy",
    "prisma:seed": "node scripts/prisma.mjs db seed",
    "prisma:studio": "node scripts/prisma.mjs studio",
    "qa:auth-smoke": "tsx scripts/qa-auth-smoke.ts",
    "build": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "preview": "vite preview",
    "start:server": "node server/dist/server/index.js"
  },
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "prisma": "^6.16.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^5.4.20"
  },
  "prisma": {
    "seed": "npm exec -- tsx prisma/seed.ts"
  }
}
