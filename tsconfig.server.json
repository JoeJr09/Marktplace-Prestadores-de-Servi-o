{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2020"],
    "ignoreDeprecations": "6.0",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noEmit": false,
    "outDir": "./server/dist",
    "rootDir": ".",
    "types": ["node"],
    "jsx": "react-jsx"
  },
  "include": ["server/**/*.ts", "server/**/*.d.ts", "shared/**/*.ts"]
}
